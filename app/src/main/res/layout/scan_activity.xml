<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark">

    <!-- Neon Glow Decor -->
    <View
        android:id="@+id/glowTop"
        android:layout_width="250dp"
        android:layout_height="250dp"
        android:background="@drawable/neon_glow_circle"
        android:alpha="0.2"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="-100dp"
        android:layout_marginEnd="-100dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:id="@+id/textViewSubjectTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="4dp"
            android:text="Scanning for Students"
            android:textColor="@color/text_main"
            android:textSize="24sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/textViewStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:letterSpacing="0.1"
            android:text="Tap below to start discovery"
            android:textAllCaps="true"
            android:textColor="@color/neon_blue"
            android:textSize="14sp" />

        <ProgressBar
            android:id="@+id/progressBarScan"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            android:indeterminate="true"
            android:indeterminateTint="@color/neon_blue"
            android:progressTint="@color/neon_blue"
            android:visibility="gone" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnStartScan"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:layout_weight="1"
                android:backgroundTint="@color/neon_blue"
                android:text="Start Scan"
                android:textAllCaps="false"
                android:textColor="@color/bg_dark"
                app:cornerRadius="12dp" />

            <Button
                android:id="@+id/btnSelectAll"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:backgroundTint="@color/bg_dark_variant"
                android:text="Select All"
                android:textAllCaps="false"
                android:textColor="@color/neon_blue"
                app:cornerRadius="12dp"
                app:strokeColor="@color/neon_blue"
                app:strokeWidth="1dp" />
        </LinearLayout>

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginBottom="24dp"
            android:layout_weight="1"
            android:background="@drawable/card_glass_bg"
            android:padding="8dp">

            <ListView
                android:id="@+id/listViewDevices"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:clipToPadding="false"
                android:divider="@color/glass_white"
                android:dividerHeight="1dp"
                android:listSelector="@android:color/transparent"
                android:scrollbarStyle="outsideOverlay" />
        </FrameLayout>

        <Button
            android:id="@+id/btnSubmitAttendance"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:backgroundTint="@color/neon_purple"
            android:elevation="8dp"
            android:text="Submit Attendance"
            android:textAllCaps="false"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:textStyle="bold"
            app:cornerRadius="12dp" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>